# Database URL (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bidstand?schema=public"

# Shared Room JWT Signing Secret (must match apps/web/.env)
ROOM_JWT_SECRET="shared-room-jwt-secret-key-between-web-and-realtime"

# CORS configuration
ALLOWED_ORIGIN="http://localhost:3000"

# Server Port
PORT=4000
