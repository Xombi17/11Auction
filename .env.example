# Database URL (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bidstand?schema=public"

# NextAuth Configuration
NEXTAUTH_SECRET="some-random-development-secret-key-at-least-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# Realtime WebSocket Server URL
NEXT_PUBLIC_REALTIME_URL="http://localhost:4000"

# Shared Room JWT Signing Secret (must match apps/realtime/.env)
ROOM_JWT_SECRET="shared-room-jwt-secret-key-between-web-and-realtime"
